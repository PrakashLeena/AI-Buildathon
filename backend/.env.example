# Copy this file to .env (for local dev) and fill in real values. Also set
# these same variables in your Vercel project settings for production.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Supabase (database) - Project Settings -> API in your Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is the SECRET key, not the anon/publishable one.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Origin of the deployed public frontend app (no trailing slash). Used for
# CORS on the public /api/registrations and /api/health routes only.
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# ---------------------------------------------------------------------------
# Admin dashboard access control
# ---------------------------------------------------------------------------
# Comma-separated list of Google account emails allowed to sign into
# /admin. Anyone else who signs in with Google will be rejected with 403,
# even though Firebase itself successfully authenticated them.
ADMIN_EMAILS=someone@example.com,someone-else@example.com

# ---------------------------------------------------------------------------
# Firebase - client config (safe to expose to the browser; NOT secret).
# Firebase Console -> Project Settings -> General -> "Your apps" -> Web app.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Firebase Admin SDK - SERVER-ONLY SECRET credentials, used to verify Google
# sign-ins and issue session cookies. NEVER prefix these with NEXT_PUBLIC_.
#
# How to get them:
#   1. Firebase Console -> Project Settings -> Service Accounts
#   2. Click "Generate new private key" -> downloads a JSON file
#   3. Copy the matching fields from that JSON into the 3 vars below
#
# FIREBASE_ADMIN_PRIVATE_KEY: paste it exactly as it appears in the JSON
# (including "-----BEGIN PRIVATE KEY-----" / "-----END PRIVATE KEY-----"),
# wrapped in quotes, with \n literally as the two characters backslash+n -
# the app converts those back into real newlines automatically.
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
