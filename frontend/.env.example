# Copy this file to .env (for local dev) and fill in real values. Also set
# these same variables in your Vercel project settings for production.
# .env is gitignored and must never be committed.

# Base URL of the backend API. Leave as "/api" for local dev (Vite proxies
# it to the backend defined by VITE_BACKEND_URL). In production, point this
# directly at your deployed Next.js backend, e.g. https://api.example.com/api
# IMPORTANT: must include the "/api" prefix and have NO trailing slash.
VITE_API_BASE_URL=/api

# Only used by vite.config.js's dev proxy target (not bundled into the app).
VITE_BACKEND_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA on the registration form) - dashboard.cloudflare.com
# -> Turnstile -> Add site. This is the PUBLIC site key (safe to expose to
# the browser). The matching secret key goes in backend/.env.example as
# TURNSTILE_SECRET_KEY - never put the secret key here.
# For local dev you can use Cloudflare's official "always passes" test key
# pair instead of a real one: sitekey 1x00000000000000000000AA / secret
# 1x0000000000000000000000000000000AA (https://developers.cloudflare.com/turnstile/troubleshooting/testing/).
# ---------------------------------------------------------------------------
VITE_TURNSTILE_SITE_KEY=
